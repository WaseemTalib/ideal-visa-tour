# Postgres connection string
# Local Postgres example: postgresql://USER:PASSWORD@localhost:5432/ideal_visa_tour
# Hosted (Neon/Supabase/Railway) example: postgresql://...?sslmode=require
DATABASE_URL=

# Optional — connection pool size (default 10)
DATABASE_POOL_MAX=

# JWT signing secret — REQUIRED. Use a long random string (>= 32 chars).
# Generate one with: openssl rand -base64 48
JWT_SECRET=

# Firebase Admin SDK — for Storage image uploads only (no Auth)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Public site URL (used by metadataBase)
NEXT_PUBLIC_SITE_URL=

# Created by `npm run db:seed`
ADMIN_EMAIL=
ADMIN_PASSWORD=
