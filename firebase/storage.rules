rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/profiles/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    match /package-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonial-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
